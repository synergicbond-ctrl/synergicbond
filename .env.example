# Public site metadata
NEXT_PUBLIC_SITE_URL=https://synergicbond.vercel.app

# Supabase client-side/public auth configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only service role key.
# Required only on server routes that bypass RLS, especially Razorpay webhooks.
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay production or test keys.
# RAZORPAY_KEY_ID is returned to the browser for Checkout.
# RAZORPAY_KEY_SECRET must remain server-only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# AI providers.
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
